# CropGuard AI — Environment Variables
# Copy this to .env in the backend folder and fill in your values
# NEVER commit .env to version control!

# Flask
SECRET_KEY=your-secret-key-change-this-in-production
FLASK_ENV=development
FLASK_DEBUG=True

# Database (default is SQLite)
DATABASE_URL=sqlite:///database/cropguard.db
# For PostgreSQL production:
# DATABASE_URL=postgresql://user:password@localhost:5432/cropguard

# Email Alerts (Optional - only needed for email notifications)
# Generate app password: https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-app-password-16-chars
MAIL_DEFAULT_SENDER=your-gmail@gmail.com

# Alert Settings
ALERT_CONFIDENCE_THRESHOLD=0.80

# Model Path (default is fine)
# MODEL_PATH=model/saved_model/crop_cnn.h5

# Frontend API URL (for CORS - usually not needed with Vite proxy)
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001
